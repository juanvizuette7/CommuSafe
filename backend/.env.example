# Configuracion base de Django
SECRET_KEY=REEMPLAZA_CON_UNA_CLAVE_SEGURA
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Base de datos local
DB_NAME=db.sqlite3

# Base de datos PostgreSQL para produccion
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=

# Seguridad en produccion
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=

# Firebase Cloud Messaging
FCM_SERVER_KEY=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_JSON_BASE64=

# IA real
# Obtener una API key gratuita en https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSy_REEMPLAZA_CON_TU_API_KEY_DE_GOOGLE_AI_STUDIO
GEMINI_MODEL=gemini-2.5-flash-lite

# Alternativa Anthropic si se decide usar Claude
LLM_API_KEY=

# Correo para recuperacion de contrasena
# En DEBUG=True se usa consola por defecto si EMAIL_BACKEND queda vacio.
EMAIL_BACKEND=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CommuSafe <no-reply@commusafe.local>

# Administrador inicial para produccion
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=
PROD_ADMIN_NOMBRE=
PROD_ADMIN_APELLIDO=
PROD_ADMIN_TELEFONO=
